# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Pipeline v2 providers
GEMINI_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=

# Pipeline v2 config
ANTHROPIC_MODEL_REASONING=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_EXTENDED_THINKING=false  # set to 'true' only if beta is verified on your account
GEMINI_MODEL=gemini-2.5-flash
COHERE_MODEL=
VOYAGE_MODEL=
PIPELINE_PARALLELISM=true
PIPELINE_LOG_LEVEL=info
PIPELINE_V2=false
PIPELINE_COST_CAP_MICROS=5000000   # $5.00 per event per calendar month

# ─── Venue Data ──────────────────────────────────────────────────────────────
# Google Places is recommended (you already have it set up, $200/mo free credit)
GOOGLE_PLACES_API_KEY=
# Yelp fallback — only needed if you don't have Google Places
YELP_API_KEY=

# ─── Email ───────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=hello@groupplan.app
SENDGRID_FROM_NAME=GroupPlan

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Photo Proxy ─────────────────────────────────────────────────────────────
# HMAC secret used to sign Google Places photo references so /api/demo/photo
# can't be used as an open relay against your Places billing quota.
# Required in every environment. Any random 32+ char string works.
PHOTO_PROXY_SECRET=

# ─── Dev / Preview Auth Bypass ───────────────────────────────────────────────
# When set, /api/dev/sign-in accepts requests that include the header
# x-preview-secret: <this value>. Use in Vercel preview environments so you
# can sign in instantly without going through email. Leave UNSET in production.
PREVIEW_BYPASS_SECRET=
