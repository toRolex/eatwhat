# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Venue Data ──────────────────────────────────────────────────────────────
# Google Places is recommended (you already have it set up, $200/mo free credit)
GOOGLE_PLACES_API_KEY=
# Yelp fallback — only needed if you don't have Google Places
YELP_API_KEY=

# ─── Email ───────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=hello@groupplan.app
SENDGRID_FROM_NAME=GroupPlan

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Photo Proxy ─────────────────────────────────────────────────────────────
# HMAC secret used to sign Google Places photo references so /api/demo/photo
# can't be used as an open relay against your Places billing quota.
# In dev this falls back to deriving from SUPABASE_SERVICE_ROLE_KEY; set it
# explicitly in production. Any random 32+ char string works.
PHOTO_PROXY_SECRET=
