{
  "name": "groupplan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "qa:visual": "playwright test -c qa-runner/playwright.visual.config.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "seed": "tsx scripts/seed.ts",
    "db:types": "supabase gen types typescript --local > packages/db/src/database.types.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.12.0",
    "prettier": "^3.2.0",
    "tsx": "^4.22.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20"
  }
}
